generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

model category_type {
  id         Int        @id @default(autoincrement())
  name       String     @unique @db.VarChar(100)
  slug       String     @unique @db.VarChar(100)
  categories category[]
  products   product[]
}

model category {
  id             Int            @id @default(autoincrement())
  name           String         @unique @db.VarChar(100)
  slug           String         @unique @db.VarChar(100)
  categoryTypeId Int?
  categoryType   category_type? @relation(fields: [categoryTypeId], references: [id])
  products       product[]
}

model color {
  id       Int               @id @default(autoincrement())
  name     String            @unique @db.VarChar(50)
  hex      String?           @db.VarChar(10)
  variants product_variant[]
}

model size {
  id       Int               @id @default(autoincrement())
  name     String            @unique @db.VarChar(20)
  order    Int               @default(0)
  variants product_variant[]
}

model product {
  id                   Int               @id @default(autoincrement())
  name                 String?           @db.VarChar(255)
  code                 String?           @unique @db.VarChar(191)
  category             String?           @db.VarChar(191)
  categoryId           Int?
  categoryTypeId       Int?
  price                Float?
  stock                Int?
  talla                String?           @db.VarChar(50)
  oferta               Boolean?          @default(false)
  visibility           String?           @default("public") @db.VarChar(191)
  status               String?           @default("active") @db.VarChar(191)
  description          String?
  image                String?
  createdAt            DateTime?         @default(now())
  updatedAt            DateTime?         @default(now()) @updatedAt
  ownerId              Int?
  commissionPercentage Float?            @default(10)
  categoryRel          category?         @relation(fields: [categoryId], references: [id])
  categoryTypeRel      category_type?    @relation(fields: [categoryTypeId], references: [id])
  variants             product_variant[]
  images               productimage[]    // ← NUEVO
}

model product_variant {
  id        Int     @id @default(autoincrement())
  productId Int
  colorId   Int
  sizeId    Int
  stock     Int     @default(0)
  product   product @relation(fields: [productId], references: [id])
  color     color   @relation(fields: [colorId], references: [id])
  size      size    @relation(fields: [sizeId], references: [id])

  @@unique([productId, colorId, sizeId])
}

model productimage {
  id        Int       @id @default(autoincrement())
  url       String?
  productId Int?
  product   product?  @relation(fields: [productId], references: [id]) // ← NUEVO
  createdAt DateTime? @default(now())
}

model order {
  id            Int         @id @default(autoincrement())
  customerName  String      @db.VarChar(191)
  customerPhone String      @db.VarChar(191)
  status        String      @default("pendiente") @db.VarChar(191)
  total         Float
  shippingCost  Float
  sellerId      Int?
  zoneId        Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  bankType      String?     @db.VarChar(191)
  paymentKey    String?     @db.VarChar(191)
  qrExpiration  DateTime?
  qrImage       String?
  items         orderitem[]
}

model orderitem {
  id        Int    @id @default(autoincrement())
  orderId   Int?
  productId Int?
  quantity  Int?
  price     Float?
  order     order? @relation(fields: [orderId], references: [id])
}

model affiliation {
  id         Int       @id @default(autoincrement())
  sellerId   Int?
  productId  Int?
  commission Float?
  createdAt  DateTime? @default(now())
}

model zone {
  id        Int       @id @default(autoincrement())
  name      String?   @db.VarChar(255)
  price     Float?
  createdAt DateTime? @default(now())
}

model user {
  id                   Int       @id @default(autoincrement())
  nombre               String    @db.VarChar(191)
  apellido             String    @db.VarChar(191)
  email                String    @unique @db.VarChar(191)
  password             String    @db.VarChar(191)
  whatsapp             String    @db.VarChar(191)
  ciudad               String    @db.VarChar(191)
  direccion            String    @db.VarChar(191)
  empresa              String    @db.VarChar(191)
  tiktok               String    @db.VarChar(191)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  passwordResetExpires DateTime?
  passwordResetToken   String?   @unique @db.VarChar(191)
  role                 String    @default("USER") @db.VarChar(50)
}